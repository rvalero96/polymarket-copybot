# Modo de trading: paper | live
TRADING_MODE=paper

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info

# Ruta de la base de datos SQLite
DB_PATH=data/state.db

# Token de autenticación para el dashboard (cámbialo!)
API_TOKEN=changeme-use-a-random-string

# Bankroll inicial en USDC (paper trading)
PAPER_BANKROLL=1000
